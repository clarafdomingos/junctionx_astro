---
import Layout from '../../layouts/Layout.astro';

const challenges = [
  {
    number: '01',
    title: 'Challenge 1',
    company: 'Partner Co.',
    logo: '../../public/assets/sponsors/nos.png',
    description: 'to be defined',
    tags: ['AI', 'Sustainability'],
    prize: 'to be defined',
  },
  {
    number: '02',
    title: 'Challenge 2',
    company: 'Sponsor Inc.',
    logo: '/assets/sponsor-logo.png',
    description: 'to be defined',
    tags: ['FinTech', 'Open Data'],
    prize: 'to be defined',
  },
  {
    number: '03',
    title: 'Challenge 3',
    company: 'Tech Corp.',
    logo: '/assets/tech-logo.png',
    description: 'to be defined',
    tags: ['Health', 'IoT'],
    prize: 'to be defined',
  },
  {
    number: '04',
    title: 'Challenge 4',
    company: 'Startup Ltd.',
    logo: '/assets/startup-logo.png',
    description: 'to be defined',
    tags: ['Smart City', 'Mobility'],
    prize: 'to be defined',
  },
];
---

<Layout title="Challenges | JunctionX Lisbon">
  <main class="challenges">
    <div class="container">
      <h2 class="h2 h2--light-purple">Challenges</h2>
      <p class="subtitle">Pick your challenge. Start here to build something that matters.</p>

      <div class="cards-grid">
        {challenges.map((c) => (
          <a class="card" >
            <div class="card__header">
              <span class="card__company">{c.company}</span>
              <span class="card__number">{c.number}</span>
            </div>

            <div class="card__logo-wrap">
              <img src={c.logo} alt={c.company} class="card__logo" />
            </div>

            <h3 class="card__title">{c.title}</h3>
            <p class="card__desc">{c.description}</p>

            <div class="card__prize">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                <path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
              </svg>
              <span>{c.prize}</span>
            </div>

            <div class="card__footer">
              <ul class="card__tags">
                {c.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <div class="card__cta">
                <span>View</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card__arrow">
                  <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .challenges {
    background: #171717;
    padding-block: clamp(48px, 7vw, 96px);
    min-height: 80dvh;
  }

  .challenges h2 {
    margin-bottom: 8px;
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.45);
    font-size: 1rem;
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  /* Card */
  .card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: rgba(167, 139, 250, 0.4);
    box-shadow: 0 0 32px rgba(167, 139, 250, 0.08);
    transform: translateY(-2px);
  }

  /* ── Header ── */
  .card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card__company {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card__number {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(167, 139, 250, 0.8);
    font-variant-numeric: tabular-nums;
  }

  /* Logo  */
  .card__logo-wrap {
    display: flex;
    align-items: center;
    width: fit-content;
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    }

    .card__logo {
    height: 28px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    }

  /* Body */
  .card__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .card__desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  /* Prize */
  .card__prize {
    display: flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 6px 12px;
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.18);
    border-radius: 8px;
    color: rgba(167, 139, 250, 0.9);
  }

  .card__prize span {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Footer */
  .card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .card__tags li {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(167, 139, 250, 0.9);
    background: rgba(167, 139, 250, 0.1);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 99px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .card__cta {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .card:hover .card__cta {
    color: rgba(167, 139, 250, 0.9);
  }

  .card__arrow {
    transition: transform 0.2s;
  }

  .card:hover .card__arrow {
    transform: translate(2px, -2px);
  }
</style>