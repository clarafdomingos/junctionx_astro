---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "JunctionX", description = "The largest AI hackaton in Lisbon" } = Astro.props;
---

<html lang="pt">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <slot />
  </body>
</html>