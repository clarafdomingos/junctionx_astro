---
import HeaderLink from './HeaderLink.astro';
---

<header id="site-header">
  <nav>
    <a href="/" class="brand" aria-label="JunctionX Lisbon">
      <img src="/assets/junctionx-logo.png" alt="JunctionX" class="nav-logo">
    </a>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="#prizes">Prizes</HeaderLink>
      <HeaderLink href="#sponsors">Sponsors</HeaderLink>
      <HeaderLink href="#faq">FAQs</HeaderLink>
      <HeaderLink href="/our_team">Our Team</HeaderLink>
      <div class="others">
        <button type="button" class="others-toggle" aria-haspopup="true" aria-expanded="false">
          Others
          <span class="others-chevron" aria-hidden="true">▾</span>
        </button>
        <div class="others-drawer">
          <div class="others-drawer-inner">
            <a href="/location">Location</a>
            <a href="/testimonials">Testimonials</a>
            <a href="/challenges">Challenges</a>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const updateHeader = () => {
    header?.classList.toggle('header--scrolled', window.scrollY > 0);
  };
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: none;
    transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
  }
  header.header--scrolled {
    backdrop-filter: saturate(160%) blur(8px);
    background: rgba(11, 10, 40, .7);
    border-bottom-color: rgba(255, 255, 255, .06);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 16px;
    padding: 12px 0 12px clamp(28px, 5vw, 64px);
  }
  .nav-logo {
    height: 80px;
    width: auto;
  }
  .internal-links {
    display: flex;
    justify-content: flex-start;
    gap: 24px;
  }
  .internal-links a {
    opacity: 0.8;
    padding: 8px 10px;
    font-weight: 700;
    white-space: nowrap;
    text-decoration: none;
    color: white;
    border-radius: 16px;
    transition: opacity 0.2s, background 0.2s;
    text-shadow: var(--text-shadow);
  }
  .internal-links a:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.1);
  }
  .internal-links a.active {
    opacity: 1;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.1);
  }
  .others {
    position: relative;
  }
  .others-toggle {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    opacity: 0.8;
    padding: 8px 10px;
    white-space: nowrap;
    color: white;
    background: none;
    border: none;
    border-radius: 16px;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    transition: opacity 0.2s, background 0.2s;
    text-shadow: var(--text-shadow);
  }
  .others-toggle:hover,
  .others:focus-within .others-toggle {
    opacity: 1;
    background: rgba(255, 255, 255, 0.1);
  }
  .others-chevron {
    font-size: 0.85em;
    line-height: 1;
    transition: transform 0.2s ease;
  }
  .others:hover .others-chevron,
  .others:focus-within .others-chevron {
    transform: translateY(1px);
  }
  .others-drawer {
    position: absolute;
    top: 100%;
    left: 0;
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    min-width: 160px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 10;
  }
  .others-drawer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 8px;
  }
  .others-drawer-inner {
    display: flex;
    flex-direction: column;
    background: rgba(11, 10, 40, .95);
    border: 1px solid rgba(255, 255, 255, .06);
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    padding: 6px;
  }
  .others:hover .others-drawer,
  .others:focus-within .others-drawer {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .others-drawer a {
    padding: 8px 10px;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    color: white;
    opacity: 0.8;
    text-shadow: var(--text-shadow);
  }
  .others-drawer a:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.1);
  }
  @media (max-width: 720px) {
    .internal-links {
      display: none;
    }
  }
</style>