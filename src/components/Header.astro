---
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="brand" aria-label="JunctionX Lisbon">
      <img src="/assets/junctionx-logo.png" alt="JunctionX" class="nav-logo">
    </a>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="#prizes">Prizes</HeaderLink>
      <HeaderLink href="#sponsors">Sponsors</HeaderLink>
      <HeaderLink href="#faq">FAQs</HeaderLink>
      <HeaderLink href="/our_team">Our Team</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0, 0.05);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 0;
  }
  .nav-logo {
    height: 48px;
    width: auto;
  }
  .internal-links {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    justify-content: center;
    gap: 24px;
  }
  .internal-links a {
    opacity: 0.8;
    padding: 8px 10px;
    font-weight: 700;
    white-space: nowrap;
    text-decoration: none;
    color: black;
    border-radius: 16px;
    transition: opacity 0.2s, background 0.2s;
  }
  .internal-links a:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.05);
  }
  .internal-links a.active {
    opacity: 1;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.05);
  }
  @media (max-width: 720px) {
    .internal-links {
      display: none;
    }
  }
</style>