---
// src/components/Sponsors.astro
const sponsors = [
  { name: "NOS", logo: "../../public/assets/sponsors/nos.png" },
  { name: "NVIDIA", logo: "../../public/assets/sponsors/nvidia.png" },
  { name: "Sponsor 3", logo: "/logos/Sponsor3.png" },
  { name: "Sponsor 4", logo: "/logos/Sponsor4.png" },
];
---

<section class="Sponsors">
  <div class="container">
    <h2 class="h2 h2--light-purple">Sponsors</h2>
  </div>

  <div class="Sponsors__track-wrapper">
    <div class="Sponsors__track">
      <div class="Sponsors__group">
        {sponsors.map((p) => (
          <div class="sponsors__logo">
            <img src={p.logo} alt={p.name} />
          </div>
        ))}
      </div>

      <div class="Sponsors__group" aria-hidden="true">
        {sponsors.map((p) => (
          <div class="sponsors__logo">
            <img src={p.logo} alt="" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .Sponsors {
    background: #171717;
    padding-block: clamp(60px, 10vw, 120px);
    overflow: hidden;
  }

  .Sponsors__track-wrapper {
    width: 100%;
    overflow: hidden;
    margin-top: 40px;
    /* fade nas pontas, opcional mas fica muito bem */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
  }

  .Sponsors__track {
    display: flex;
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  .Sponsors__group {
    display: flex;
    align-items: center;
    gap: 60px;
    flex-shrink: 0;
    /* THIS is important */
    padding-right: 60px;
  }

  @keyframes scroll {
    to {
      transform: translateX(calc(-100% / 2));
    }
  }

  .Sponsors__track:hover {
    animation-play-state: paused;
  }

  .sponsors__logo {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 60px;
    width: 160px;
  }

  .sponsors__logo img {
    max-width: 100%;  
    max-height: 100%;
    object-fit: contain;
    opacity: 0.7;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .sponsors__logo img:hover {
    opacity: 1;
  }

  @keyframes scroll-Sponsors {
    from {
      transform: translateX(0);
    }
    to {
      /* anda exatamente metade da largura, pois a lista está duplicada */
      transform: translateX(-50%);
    }
  }
</style>